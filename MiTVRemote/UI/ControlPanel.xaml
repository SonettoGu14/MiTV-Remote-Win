<Window x:Class="MiTVRemote.UI.ControlPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiTV Remote"
        Width="280" Height="380"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="False">
    <StackPanel Margin="12" Orientation="Vertical">

            <!-- 设备信息 -->
            <TextBlock Name="DeviceInfoLabel" Text=""
                       FontSize="12" Margin="0,0,0,8" />

            <!-- 音量区域 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Name="VolumeDownBtn" Content="−" Width="32" Height="28"
                        FontSize="16" FontWeight="Bold" />
                <Slider Name="VolumeSlider" Minimum="0" Maximum="100"
                        Margin="6,0" Width="160" />
                <Button Name="VolumeUpBtn" Content="+" Width="32" Height="28"
                        FontSize="16" FontWeight="Bold" />
            </StackPanel>

            <TextBlock Name="VolumeLabel" Text="50%" FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,4,0,12" />

            <!-- 导航键 (D-pad) -->
            <Grid Width="120" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="36" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>

                <Button Name="UpBtn" Content="▲" Grid.Row="0" Grid.Column="1" />
                <Button Name="LeftBtn" Content="◀" Grid.Row="1" Grid.Column="0" />
                <Button Name="OkBtn" Content="OK" Grid.Row="1" Grid.Column="1"
                        FontSize="10" FontWeight="Bold" />
                <Button Name="RightBtn" Content="▶" Grid.Row="1" Grid.Column="2" />
                <Button Name="DownBtn" Content="▼" Grid.Row="2" Grid.Column="1" />
            </Grid>

            <!-- 功能按键行 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Button Name="HomeBtn" Content="🏠" Width="40" Height="32" Margin="2" />
                <Button Name="BackBtn" Content="↩" Width="40" Height="32" Margin="2" />
                <Button Name="MenuBtn" Content="☰" Width="40" Height="32" Margin="2" />
                <Button Name="PowerBtn" Content="⏻" Width="40" Height="32" Margin="2" />
            </StackPanel>

            <!-- HDMI 切换 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,12">
                <Button Name="Hdmi1Btn" Content="HDMI 1" Width="70" Height="28" Margin="2" />
                <Button Name="Hdmi2Btn" Content="HDMI 2" Width="70" Height="28" Margin="2" />
            </StackPanel>

            <!-- 发现设备按钮 -->
            <Button Name="DiscoverBtn" Width="100" Height="28"
                    HorizontalAlignment="Center" />

        </StackPanel>
</Window>
